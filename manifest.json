{
  "manifest_version": 3,
  "name": "FB Click Warning",
  "version": "1.0",
  "permissions": ["tabs", "webNavigation"],
  "host_permissions": ["*://www.facebook.com/*", "*://*.facebook.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["warning.html", "warning.js"],
    "matches": ["<all_urls>"]
  }]
}